# =====================================================================
# Cognivest — environment template
# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).
# =====================================================================

# ---- App ----
APP_ENV=development                 # development | staging | production
APP_NAME=cognivest
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Backend / FastAPI ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=cognivest
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cognivest
DATABASE_URL=postgresql+asyncpg://cognivest:change_me@postgres:5432/cognivest

# ---- Redis (cache + Celery broker/backend) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Auth / JWT (RS256 — provide PEM keys or paths) ----
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
SERVICE_TOKEN=change_me_internal_service_token   # for /memory/* internal calls

# ---- OAuth (Google) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Cognee: LLM + embeddings (shared env namespace) ----
# IMPORTANT — read before changing:
#  (a) These names (LLM_*, EMBEDDING_*) are Cognee's own pydantic BaseSettings
#      field names, NOT ours. Do NOT rename or prefix them (a `COGNEE_` prefix
#      is inert — Cognee reads the bare names). Verified in
#      docs/spike-cognee-1.2.2.md §3.
#  (b) `import cognee` runs `dotenv.load_dotenv(override=True)` at import time
#      (cognee/__init__.py:11), so THIS FILE's values win over anything already
#      in os.environ. Whatever you set here is what Cognee actually uses.
#  (c) WARNING: changing EMBEDDING_* after data has been ingested requires a
#      prune + re-cognify. A dimension mismatch is destructive — it silently
#      breaks vector writes (spike §3: unset dims fall back to 3072).
#
# A single LLM provider (Gemini, via litellm) powers both graph construction
# (cognify) and answer generation (completion search types).
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash        # litellm format; 2.0-flash is deprecated (spike §5)
LLM_API_KEY=
EMBEDDING_PROVIDER=fastembed             # local ONNX; no embedding API key needed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384                 # MUST match the model; do not omit (spike §3)

# ---- Cognee: vector / graph / data dir ----
# UNVERIFIED — scaffold legacy. The spike (docs/spike-cognee-1.2.2.md) did NOT
# confirm Cognee reads these `COGNEE_`-prefixed names; §5 shows the analogous
# COGNEE_LLM_PROVIDER is ignored. lancedb + kuzu are Cognee's defaults, but the
# env-var wiring below is unconfirmed. Left commented until verified.
# COGNEE_VECTOR_DB_PROVIDER=lancedb        # lancedb | weaviate | qdrant ...
# COGNEE_GRAPH_DB_PROVIDER=kuzu            # kuzu | neo4j ...
# COGNEE_DATA_DIR=/data/cognee

# ---- External data vendors (all pluggable) ----
MARKET_DATA_PROVIDER=polygon             # polygon | iex | alphavantage
MARKET_DATA_API_KEY=
NEWS_API_PROVIDER=newsapi                 # newsapi | gdelt
NEWS_API_KEY=
WEB_SEARCH_PROVIDER=tavily                # tavily | serper
WEB_SEARCH_API_KEY=

# ---- Scheduling (per-ticker defaults; override per company) ----
PRICE_COLLECT_CRON=0 22 * * 1-5          # end-of-day weekdays
NEWS_COLLECT_INTERVAL_HOURS=2
INGEST_DEDUP_ENABLED=true

# ---- Rate limiting ----
QUERY_RATE_LIMIT_PER_MINUTE=20

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
